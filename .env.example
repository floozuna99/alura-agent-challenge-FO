# Copiá este archivo como ".env" y completá con tus valores reales
# NUNCA subas el archivo ".env" real a GitHub (ya está en .gitignore)

# Tu API key gratuita de Cohere -> https://dashboard.cohere.com/api-keys
COHERE_API_KEY=tu_api_key_aqui

# Ruta al documento PDF que va a usar el agente
PDF_PATH=data/documento.pdf

# Carpeta donde se guarda el índice vectorial generado
INDEX_PATH=data/faiss_index

# Puerto del servidor (Flask usa 8080 por defecto en este proyecto)
PORT=8080
